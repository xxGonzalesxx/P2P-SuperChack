<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SuperChack.Avalonia.ViewModels"
        xmlns:views="using:SuperChack.Avalonia.Views"
        x:Class="SuperChack.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SuperChack P2P Мессенджер"
        Width="500" Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>

    <ContentControl Content="{Binding CurrentView}">
        <ContentControl.DataTemplates>
            <DataTemplate DataType="{x:Type vm:ConnectViewModel}">
                <views:ConnectView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ChatViewModel}">
                <views:ChatView/>
            </DataTemplate>
        </ContentControl.DataTemplates>
    </ContentControl>
</Window>