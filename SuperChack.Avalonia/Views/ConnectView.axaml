<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SuperChack.Avalonia.ViewModels"
             x:Class="SuperChack.Avalonia.Views.ConnectView"
             x:DataType="vm:ConnectViewModel">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                Spacing="16" Width="300">

        <TextBlock Text="SuperChack P2P Мессенджер"
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"/>

        <TextBox PlaceholderText="Твоё имя" Text="{Binding Name}"/>
        <TextBox PlaceholderText="IP друга (Radmin VPN)" Text="{Binding PeerIp}"/>

        <TextBlock Text="{Binding ErrorMessage}"
                   Foreground="Red" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

        <Button Content="Подключиться"
                Command="{Binding ConnectCommand}"
                HorizontalAlignment="Stretch"
                HorizontalContentAlignment="Center"/>
    </StackPanel>
</UserControl>